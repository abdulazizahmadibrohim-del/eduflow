{
  "installCommand": "cd artifacts/eduflow && npm install --include=dev",
  "buildCommand": "cd artifacts/eduflow && npx expo export --platform web",
  "outputDirectory": "artifacts/eduflow/dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
